# -----------------------------------------------------------------------
# App
# -----------------------------------------------------------------------
PORT=4000
APP_URL=http://localhost:4000

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/database-name

# -----------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------
JWT_SECRET=your-super-secret-key-change-me-in-production
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=3d

# -----------------------------------------------------------------------
# SMTP (Mailtrap sandbox for dev — replace with real SMTP in production)
# -----------------------------------------------------------------------
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
SMTP_FROM="App Name <no-reply@your-domain.com>"
